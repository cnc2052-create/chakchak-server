# ────────────────────────────────────────
# 착착(ChakChak) 환경변수 설정
# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요
# ────────────────────────────────────────

# Claude API (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Meta / Instagram
INSTAGRAM_PAGE_TOKEN=EAAxxxxxxxxxxxxxxxx
WEBHOOK_VERIFY_TOKEN=chakchak_secret_2024   # 본인이 원하는 문자열로 설정

# Supabase (https://supabase.com 에서 프로젝트 생성 후 발급)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx

# 숍 정보
SHOP_NAME=미소 헤어숍
OWNER_PHONE=010-0000-0000

# 슬랙 예약 알림 (선택사항 - 없으면 콘솔 출력만)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# 서버 포트
PORT=3000
